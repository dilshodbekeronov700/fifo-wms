<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="24dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImportBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="148dp"
            app:cardBackgroundColor="@color/dashboard_production"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:rippleColor="@color/card_ripple"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="148dp"
                android:padding="24dp"
                android:text="@string/import_option_box"
                android:textAlignment="center"
                android:textColor="@color/dashboard_text_on_production"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImportTransport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="148dp"
            app:cardBackgroundColor="@color/dashboard_production"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:rippleColor="@color/card_ripple"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="148dp"
                android:padding="24dp"
                android:text="@string/import_option_transport"
                android:textAlignment="center"
                android:textColor="@color/dashboard_text_on_production"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
