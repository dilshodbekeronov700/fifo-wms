<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- Progress bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/putawayProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:indicatorColor="@color/dashboard_production"
            app:trackColor="#E0E0E0"
            app:trackThickness="4dp" />

        <!-- Hint -->
        <TextView
            android:id="@+id/tvPutawayHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#E8F4FD"
            android:padding="14dp"
            android:text="@string/putaway_hint"
            android:textColor="#1565C0"
            android:textSize="15sp"
            android:gravity="center" />

        <!-- Scanned code -->
        <TextView
            android:id="@+id/tvPutawayScannedCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="monospace"
            android:textColor="#666666"
            android:textSize="12sp" />

        <!-- Product name -->
        <TextView
            android:id="@+id/tvPutawayProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Suggestions container -->
        <LinearLayout
            android:id="@+id/containerSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Reset button -->
        <Button
            android:id="@+id/btnPutawayReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/putaway_reset"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
