{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd wms/frontend && npm install && npm run build",
  "outputDirectory": "wms/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://REPLACE-WITH-RENDER-URL.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
