{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd wms/frontend && npm install && npm run build",
  "outputDirectory": "wms/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://wms-backend-pj1v.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
