# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=WMS
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wms:wms@localhost:5432/wms
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Security ──────────────────────────────────────────────────────────────────
# Production (DEBUG=false): kamida 32 belgi, andoza bo'lmasin. Yangi sir:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
# Connector sirlari uchun alohida shifrlash kaliti (production'da majburiy tavsiya).
# ENCRYPTION_KEY=
# Production'da aniq domenlar (vergul bilan). Dev'da '*'.
CORS_ORIGINS=*

# ── Observability ─────────────────────────────────────────────────────────────
# Production'da strukturali (JSON) log.
LOG_JSON=false
# Bo'sh bo'lsa Sentry o'chiq. sentry-sdk o'rnatilgan bo'lishi kerak.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Connector resilience (circuit breaker) ────────────────────────────────────
CIRCUIT_FAIL_THRESHOLD=5
CIRCUIT_RESET_SECONDS=60
